{
  "name": "enthropic",
  "version": "0.1.1",
  "description": "CLI for the Enthropic architectural specification format",
  "license": "MIT",
  "author": "Enthropic-spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Enthropic-spec/enthropic-tools.git"
  },
  "keywords": [
    "enthropic",
    "enth",
    "spec",
    "architecture",
    "ai",
    "cli",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "enthropic": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node -e \"import('fs').then(fs=>{try{fs.rmSync('dist',{recursive:true})}catch{}})\"",
    "build": "bun build src/index.ts --outfile dist/index.js --target node --packages=external --format esm && node -e \"import('fs').then(fs=>{const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);fs.chmodSync(f,0o755);})\"",
    "prepare": "npm run build",
    "binary:mac": "bun build src/index.ts --compile --outfile releases/enthropic-macos-arm64 --target bun-darwin-arm64",
    "binary:linux": "bun build src/index.ts --compile --outfile releases/enthropic-linux-x64 --target bun-linux-x64",
    "binary:win": "bun build src/index.ts --compile --outfile releases/enthropic-windows-x64.exe --target bun-windows-x64",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.4.0",
    "@noble/ciphers": "^1.3.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3"
  }
}
