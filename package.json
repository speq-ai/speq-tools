{
  "name": "enthropic",
  "version": "0.1.0",
  "description": "CLI for the Enthropic architectural specification format",
  "license": "MIT",
  "author": "Enthropic-spec",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enthropic-spec/enthropic-tools.git"
  },
  "keywords": ["enthropic", "enth", "spec", "architecture", "ai", "cli", "mcp"],
  "type": "module",
  "bin": {
    "enthropic": "dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"import('fs').then(fs=>{const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);fs.chmodSync(f,0o755);})\"",
    "prepare": "npm run build",
    "bundle": "ncc build dist/index.js -o bundle --minify",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.4.0",
    "@noble/ciphers": "^1.3.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3"
  }
}
